@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="page-section">
    <div class="privacy-card">
        <span class="eyebrow">Privacy</span>
        <h1>Employee data should be handled with care.</h1>
        <p>
            This portal is intended to store employee details in a clear and controlled way. Access should be limited to authorized users, and records should be reviewed regularly for accuracy.
        </p>
        <p>
            If this project evolves beyond a sample application, the next step should be adding authentication, authorization, persistent storage, and auditing for create, edit, and delete actions.
        </p>
        <div class="hero-actions mt-4">
            <a asp-controller="Employee" asp-action="Index" class="btn btn-primary">Go to Employee Directory</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back to Home</a>
        </div>
    </div>
</section>
