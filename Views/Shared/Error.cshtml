@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="page-section">
    <div class="error-card">
        <span class="eyebrow">Something went wrong</span>
        <h1>We couldn't complete that request.</h1>
        <p>Please try again, or return to a safer page in the portal.</p>

        @if (Model.ShowRequestId)
        {
            <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }

        <div class="danger-banner mt-4">
            Development mode shows more detailed error information. Avoid enabling it in deployed environments that real users can access.
        </div>

        <div class="hero-actions mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Home</a>
            <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-secondary">Open Employees</a>
        </div>
    </div>
</section>
