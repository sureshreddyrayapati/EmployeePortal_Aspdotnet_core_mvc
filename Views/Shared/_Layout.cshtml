<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Employee Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PracticeAspcoreMVC.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "Home";
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "Index";
        var isLoginPage = currentController == "Account" && currentAction == "Login";
        var loggedInUser = Context.Session.GetString("LoggedInUser");

        var pageTitle = currentController switch
        {
            "Account" when currentAction.Equals("Login", StringComparison.OrdinalIgnoreCase) => "Login",
            "Employee" when currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase) => "Employee Directory",
            "Employee" when currentAction.Equals("Create", StringComparison.OrdinalIgnoreCase) => "Add Employee",
            "Employee" when currentAction.Equals("Edit", StringComparison.OrdinalIgnoreCase) => "Edit Employee",
            "Employee" when currentAction.Equals("Delete", StringComparison.OrdinalIgnoreCase) => "Delete Employee",
            "Home" when currentAction.Equals("Privacy", StringComparison.OrdinalIgnoreCase) => "Privacy & Data",
            _ => "Employee Portal"
        };

        var pageSubtitle = currentController switch
        {
            "Account" when currentAction.Equals("Login", StringComparison.OrdinalIgnoreCase) => "Sign in with the static admin account to access the portal.",
            "Employee" when currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase) => "Track your team, search records quickly, and manage updates from one place.",
            "Employee" when currentAction.Equals("Create", StringComparison.OrdinalIgnoreCase) => "Capture employee details with a simple, focused form.",
            "Employee" when currentAction.Equals("Edit", StringComparison.OrdinalIgnoreCase) => "Keep employee records accurate and current.",
            "Employee" when currentAction.Equals("Delete", StringComparison.OrdinalIgnoreCase) => "Review the record carefully before removing it permanently.",
            "Home" when currentAction.Equals("Privacy", StringComparison.OrdinalIgnoreCase) => "A quick summary of how this portal should treat employee information.",
            _ => "A cleaner workspace for HR tasks, employee records, and day-to-day operations."
        };
    }

    @if (isLoginPage)
    {
        <main class="login-page-shell" role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="app-shell">
            <aside class="app-sidebar">
                <div class="d-flex align-items-center gap-3">
                    <div class="brand-mark">EP</div>
                    <div>
                        <div class="fw-bold fs-4">Employee Portal</div>
                        <div class="text-white-50">People operations dashboard</div>
                    </div>
                </div>

                <p class="sidebar-note">
                    Keep employee information tidy, accessible, and easy to manage from any screen size.
                </p>

                <nav class="sidebar-nav">
                    <a class="nav-card @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <span class="nav-icon">H</span>
                        <span>
                            <span class="nav-title">Home</span>
                            <span class="nav-subtitle">Overview and quick actions</span>
                        </span>
                    </a>

                    <a class="nav-card @(currentController == "Employee" ? "active" : "")" asp-controller="Employee" asp-action="Index">
                        <span class="nav-icon">E</span>
                        <span>
                            <span class="nav-title">Employees</span>
                            <span class="nav-subtitle">Directory, create, edit, and delete</span>
                        </span>
                    </a>

                    <a class="nav-card @(currentController == "Home" && currentAction == "Privacy" ? "active" : "")" asp-controller="Home" asp-action="Privacy">
                        <span class="nav-icon">P</span>
                        <span>
                            <span class="nav-title">Privacy</span>
                            <span class="nav-subtitle">Guidance for handling employee data</span>
                        </span>
                    </a>
                </nav>
            </aside>

            <main class="app-main">
                <div class="page-wrap">
                    <div class="mobile-nav">
                        <a class="nav-card @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">
                            <span class="nav-icon">H</span>
                            <span class="nav-title">Home</span>
                        </a>
                        <a class="nav-card @(currentController == "Employee" ? "active" : "")" asp-controller="Employee" asp-action="Index">
                            <span class="nav-icon">E</span>
                            <span class="nav-title">Employees</span>
                        </a>
                        <a class="nav-card @(currentController == "Home" && currentAction == "Privacy" ? "active" : "")" asp-controller="Home" asp-action="Privacy">
                            <span class="nav-icon">P</span>
                            <span class="nav-title">Privacy</span>
                        </a>
                    </div>

                    <header class="topbar">
                        <div>
                            <span class="eyebrow">Modern Workforce UI</span>
                            <h1 class="page-title">@pageTitle</h1>
                            <p class="page-subtitle">@pageSubtitle</p>
                        </div>
                        <div class="topbar-actions">
                            @if (!string.IsNullOrEmpty(loggedInUser))
                            {
                                <span class="topbar-badge">Signed in as @loggedInUser</span>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-secondary">Logout</button>
                                </form>
                            }
                        </div>
                    </header>

                    <main role="main">
                        @RenderBody()
                    </main>

                    <footer class="footer-note">
                        &copy; 2026 Employee Portal. Built for fast employee management across desktop and mobile.
                    </footer>
                </div>
            </main>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
