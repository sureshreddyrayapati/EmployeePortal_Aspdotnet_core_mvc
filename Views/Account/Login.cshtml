@model PracticeAspcoreMVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<section class="login-wrap">
    <div class="login-panel">
        <div class="login-copy">
            <span class="eyebrow">Secure Entry</span>
            <h1>Sign in to open the employee portal.</h1>
            <p>
                Access employee records, manage updates, and continue your daily HR workflow from one secure place.
            </p>

            <div class="login-hint">
                <div class="hint-row">
                    <span class="hint-label">Employee records</span>
                    <strong>Organized and easy to manage</strong>
                </div>
                <div class="hint-row">
                    <span class="hint-label">Portal access</span>
                    <strong>Protected with sign-in</strong>
                </div>
            </div>
        </div>

        <div class="login-card">
            <div class="form-header">
                <div>
                    <span class="eyebrow">Welcome back</span>
                    <h2>Login</h2>
                    <p>Enter your credentials to continue.</p>
                </div>
            </div>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="field-block">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" placeholder="Enter username" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="field-block mt-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" placeholder="Enter password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="hero-actions mt-4">
                    <button type="submit" class="btn btn-primary">Login</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
