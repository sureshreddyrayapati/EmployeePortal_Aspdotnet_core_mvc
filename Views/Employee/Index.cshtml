@model List<PracticeAspcoreMVC.Models.Employee>
@{
   
    var currentFilter = ViewData["CurrentFilter"] as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="text-primary mb-0">Employee List</h2>
    </div>
    <form asp-action="Index" method="get" class="d-flex" role="search">
        <input name="searchTerm" value="@currentFilter" class="form-control me-2" placeholder="🔍Search name, location, age or ID..." />
        <button type="submit" class="btn btn-outline-secondary me-2">Search</button>
        <a asp-action="Index" class="btn btn-link">Clear</a>
    </form>
</div>


<a class="btn btn-success mb-3" asp-controller="Employee" asp-action="Create">
    Add New Employee
</a>

<table class="table table-bordered table-striped table-hover shadow-sm">
    <thead class="table-dark text-center">
        <tr>
            <th scope="col">#</th>
            <th scope="col">Employee Name</th>
            <th scope="col">Age</th>
            <th scope="col">Joining Date</th>
            <th scope="col">Location</th>
             <th scope="col">Actions</th> 
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td class="text-center">@emp.EmployeeId</td>
                <td>@emp.EmployeeName</td>
                <td class="text-center">@emp.EmployeeAge</td>
                <td class="text-center">@emp.JoingDate.ToString("dd-MMM-yyyy")</td>
                <td>@emp.Location</td>
                
                <td class="text-center">
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@emp.EmployeeId">Edit</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@emp.EmployeeId">Delete</a>
                </td>
                
            </tr>
        }
    </tbody>
</table>
