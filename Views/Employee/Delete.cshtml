@model PracticeAspcoreMVC.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<section class="page-section">
    <div class="details-card">
        <div class="details-header">
            <div>
                <span class="eyebrow">Delete</span>
                <h2>Confirm employee removal</h2>
                <p>Review the details below before deleting this employee record from the directory.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>

        <div class="danger-banner">
            This action will remove the employee from the current in-memory list. Please confirm before continuing.
        </div>

        <dl class="details-grid">
            <div class="detail-item">
                <dt>Employee ID</dt>
                <dd>#@Model.EmployeeId</dd>
            </div>
            <div class="detail-item">
                <dt>Employee Name</dt>
                <dd>@Model.EmployeeName</dd>
            </div>
            <div class="detail-item">
                <dt>Age</dt>
                <dd>@Model.EmployeeAge years</dd>
            </div>
            <div class="detail-item">
                <dt>Joining Date</dt>
                <dd>@Model.JoingDate.ToString("dd MMM yyyy")</dd>
            </div>
            <div class="detail-item">
                <dt>Location</dt>
                <dd>@Model.Location</dd>
            </div>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="EmployeeId" />
            <div class="hero-actions">
                <button type="submit" class="btn btn-danger">Delete Employee</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</section>
