@model PracticeAspcoreMVC.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<section class="page-section">
    <div class="form-shell">
        <div class="form-header">
            <div>
                <span class="eyebrow">Update</span>
                <h2>Edit employee details</h2>
                <p>Adjust the employee record and save your changes when everything looks right.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="EmployeeId" />

            <div class="form-grid">
                <div class="field-block field-block-full">
                    <label asp-for="EmployeeName" class="form-label"></label>
                    <input asp-for="EmployeeName" class="form-control" placeholder="Enter full name" />
                    <span asp-validation-for="EmployeeName" class="text-danger small"></span>
                </div>

                <div class="field-block">
                    <label asp-for="EmployeeAge" class="form-label"></label>
                    <input asp-for="EmployeeAge" class="form-control" type="number" placeholder="Enter age" />
                    <span asp-validation-for="EmployeeAge" class="text-danger small"></span>
                </div>

                <div class="field-block">
                    <label asp-for="JoingDate" class="form-label"></label>
                    <input asp-for="JoingDate" class="form-control" type="date" />
                    <span asp-validation-for="JoingDate" class="text-danger small"></span>
                </div>

                <div class="field-block field-block-full">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" placeholder="Enter city or branch name" />
                    <span asp-validation-for="Location" class="text-danger small"></span>
                </div>
            </div>

            <div class="hero-actions mt-4">
                <button type="submit" class="btn btn-warning">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
