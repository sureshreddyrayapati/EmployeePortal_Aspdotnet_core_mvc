@model PracticeAspcoreMVC.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded">
        <div class="card-header bg-primary text-dark">
            <h4 class="mb-0">✏️ Edit Employee</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="EmployeeId" />

                <div class="row gy-3">
                    <div class="col-md-6">
                        <label asp-for="EmployeeName" class="form-label fw-semibold"></label>
                        <input asp-for="EmployeeName" class="form-control" placeholder="Enter full name" />
                        <span asp-validation-for="EmployeeName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="EmployeeAge" class="form-label fw-semibold"></label>
                        <input asp-for="EmployeeAge" class="form-control" type="number" placeholder="Age" />
                        <span asp-validation-for="EmployeeAge" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="JoingDate" class="form-label fw-semibold"></label>
                        <input asp-for="JoingDate" class="form-control" type="date" />
                        <span asp-validation-for="JoingDate" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label fw-semibold"></label>
                        <input asp-for="Location" class="form-control" placeholder="City or branch" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-warning px-4">Update</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
